[flake8]
# Configuration kept in sync with pyproject.toml [tool.flake8]
# This file kept for tools that don't support pyproject.toml yet
max-line-length = 150
extend-ignore = E203, E266, E501, E402, W503, DJ01
exclude =
    .git,
    __pycache__,
    */__init__.py,
    migrations,
    .venv,
    build,
    dist
